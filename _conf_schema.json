{
  "stats_mode": {
    "type": "string",
    "description": "统计模式",
    "hint": "window=窗口统计(每个窗口独立计数)；global=全局统计(所有窗口共享同一provider的用量计数)",
    "default": "window"
  },
  "windows": {
    "type": "object",
    "description": "窗口配置",
    "hint": "每个窗口对应一个对话窗口(UMO)。UMO留空的窗口不会生效。",
    "items": {
      "window_1": {
        "type": "object",
        "description": "窗口 1",
        "items": {
          "umo": {
            "type": "string",
            "description": "对话窗口UMO号",
            "hint": "格式: platform_id:message_type:session_id，例如 aiocqhttp:GroupMessage:123456。留空则不启用此窗口。"
          },
          "models": {
            "type": "template_list",
            "description": "模型路由列表",
            "hint": "按顺序配置模型路由链。当模型1达到限额后切换到模型2，以此类推。模型1应与框架默认模型一致。",
            "templates": {
              "model": {
                "name": "模型",
                "items": {
                  "provider_id": {
                    "type": "string",
                    "description": "Provider ID",
                    "hint": "格式: 提供商源ID/模型名，如 火山/doubao-seed-2-0-pro-260215"
                  },
                  "daily_limit": {
                    "type": "int",
                    "description": "每日用量限额(token)",
                    "hint": "达到此限额后切换到下一个模型",
                    "default": 200000
                  }
                }
              }
            },
            "default": []
          }
        }
      },
